# --- GitHub --------------------------------------------------------------
# PAT from https://github.com/settings/tokens
# Scopes:  read:user   (required, lets private contribs show in your graph total)
#          repo        (optional, only if you want commit messages/refs later)
GITHUB_TOKEN=
GITHUB_LOGIN=anishthite

# --- Twitter / X ---------------------------------------------------------
# Your X handle (no leading @).
X_LOGIN=anishthite

# Self-hosted Nitter host — the PRIMARY Twitter source.
#
# Hostname only (no protocol, no trailing slash, no path). The dashboard
# will hit https://<host>/<handle>/rss to read your X timeline.
#
# Setup is a one-time ~1h Fly.io deploy of a personal Nitter instance
# backed by a *burner* X account (never use your real account). See
# docs/SELF_HOST_NITTER.md for the full walkthrough.
#
# If this is unset, the dashboard falls back to syndication.twitter.com
# (months-stale data, see twitter.ts D-027) and then to the public Nitter
# pool (usually blocked from Vercel egress IPs). Twitter panel will
# work-ish but the recent-days bucket will be wrong until you self-host.
#
# Example: X_NITTER_HOST=my-nitter.fly.dev
X_NITTER_HOST=

# --- Dashboard auth (Phase 3+) ------------------------------------------
NERV_PILOT_TOKEN=

# --- One-liner LLM (optional) -------------------------------------------
# If set, the dashboard's nudge line is generated by Claude Haiku.
# If unset, a deterministic rule-based pool is used (free, no API call).
# Get a key at https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=

# --- Misc ----------------------------------------------------------------
# IANA timezone used for day-bucketing & streak math.
NERV_TZ=America/Los_Angeles
