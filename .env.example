# --- GitHub --------------------------------------------------------------
# PAT from https://github.com/settings/tokens
# Scopes:  read:user   (required, lets private contribs show in your graph total)
#          repo        (optional, only if you want commit messages/refs later)
GITHUB_TOKEN=
GITHUB_LOGIN=anishthite

# --- Twitter / X ---------------------------------------------------------
# Your X handle (no leading @). Used to build the Nitter RSS URL.
X_LOGIN=anishthite

# --- Dashboard auth (Phase 3+) ------------------------------------------
NERV_PILOT_TOKEN=

# --- One-liner LLM (optional) -------------------------------------------
# If set, the dashboard's nudge line is generated by Claude Haiku.
# If unset, a deterministic rule-based pool is used (free, no API call).
# Get a key at https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=

# --- Misc ----------------------------------------------------------------
# IANA timezone used for day-bucketing & streak math.
NERV_TZ=America/Los_Angeles
