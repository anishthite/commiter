# --- GitHub --------------------------------------------------------------
# PAT from https://github.com/settings/tokens
# Scopes:  read:user   (required, lets private contribs show in your graph total)
#          repo        (optional, only if you want commit messages/refs later)
GITHUB_TOKEN=
GITHUB_LOGIN=anishthite

# --- Twitter / X ---------------------------------------------------------
# Your X handle (no leading @).
X_LOGIN=anishthite

# rettiwt-api API key — the PRIMARY (and only chronological) Twitter source.
# Without this, the dashboard falls back to syndication.twitter.com which
# returns a stale curated set of tweets (months out of date), then to a
# Nitter pool that's almost always blocked from datacenter IPs.
#
# How to obtain (one-time, ~2 minutes):
#   1. Chrome: install "X Auth Helper"
#      https://chromewebstore.google.com/detail/x-auth-helper/igpkhkjmpdecacocghpgkghdcmcmpfhp
#      Firefox: install "Rettiwt Auth Helper"
#      https://addons.mozilla.org/en-US/firefox/addon/rettiwt-auth-helper
#   2. Allow the extension in incognito/private mode.
#   3. Open an incognito window and log in to x.com.
#   4. While still on x.com, click the extension → "Get Key" → copy.
#   5. Paste below (and into Vercel env vars for prod).
#   6. Close the incognito window WITHOUT logging out — the key stays
#      valid until you explicitly log out from that session.
#
# Note: this is base64'd auth cookies. Treat it like a password — anyone
# with this string can read DMs and act as your account. Vercel env vars
# are encrypted at rest; storing it in .env.local is fine for dev.
X_RETTIWT_KEY=

# --- Dashboard auth (Phase 3+) ------------------------------------------
NERV_PILOT_TOKEN=

# --- One-liner LLM (optional) -------------------------------------------
# If set, the dashboard's nudge line is generated by Claude Haiku.
# If unset, a deterministic rule-based pool is used (free, no API call).
# Get a key at https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=

# --- Misc ----------------------------------------------------------------
# IANA timezone used for day-bucketing & streak math.
NERV_TZ=America/Los_Angeles
