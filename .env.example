# --- GitHub --------------------------------------------------------------
# PAT from https://github.com/settings/tokens
# Scopes:  read:user   (required, lets private contribs show in your graph total)
#
# Multi-user note (2026-06-01): the user roster lives in
# apps/web/src/config/users.json. Each entry has its own GitHub login.
# The same GITHUB_TOKEN is used to fetch every user's PUBLIC contributions
# graph via GraphQL (no per-user PAT required). GITHUB_LOGIN below is
# retained only as a fallback for the legacy single-user /api/snapshot
# call without a `?user=` slug; the multi-user routes ignore it.
GITHUB_TOKEN=
GITHUB_LOGIN=anishthite

# --- Twitter / X ---------------------------------------------------------
# Multi-user note: each roster entry in apps/web/src/config/users.json
# carries its own X login. The bundled tweet day-counts live in
# apps/web/src/data/x-days-by-slug.json, refreshed by
# .github/workflows/refresh-x-days.yml. The runtime does NOT fetch from X.
#
# X_LOGIN here is OPTIONAL — it's only used by the refresh script's
# legacy single-user override path (run `X_LOGIN=foo pnpm tsx
# scripts/refresh-x-days.ts` locally to test one handle without editing
# the roster). Leave it unset in production.
# X_LOGIN=

# --- Misc ----------------------------------------------------------------
# IANA timezone used for day-bucketing & streak math.
NERV_TZ=America/Los_Angeles

# --- GitHub Action secrets (NOT for .env.local) -------------------------
# These belong in GitHub → Settings → Secrets and variables → Actions.
# The runtime app never reads them; only the daily refresh workflow does.
#
# SOCIALDATA_API_KEY — Bearer token for https://api.socialdata.tools.
#   Used by scripts/refresh-x-days.ts (invoked by the daily Action) to
#   look up the user_id and paginate `from:<handle> since:<date>`.
#   Required for the workflow to succeed; not required for `pnpm dev`
#   or any user-facing render.
