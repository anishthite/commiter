# --- GitHub --------------------------------------------------------------
# PAT from https://github.com/settings/tokens
# Scopes:  read:user   (required, lets private contribs show in your graph total)
#          repo        (optional, only if you want commit messages/refs later)
GITHUB_TOKEN=
GITHUB_LOGIN=anishthite

# --- Twitter / X ---------------------------------------------------------
# Your X handle (no leading @).
X_LOGIN=anishthite

# === Twitter source: pick AT MOST ONE of the two below =================
# If neither is set, the Twitter panel is HIDDEN on the dashboard — the
# GitHub panel widens to fill the row and "did we ship today?" answers
# from GitHub alone. That's a perfectly valid configuration; set one of
# these only when you have a data source.

# X_DATA_URL — the modern, sane way: point at a JSON file produced by
# whatever scraper you build (a userscript on your laptop, a hosted
# browser cron, a Mac mini at home, a paid API — commiter doesn't care).
#
# Wire format (one of):
#   [{"date":"2026-05-29","count":3},{"date":"2026-05-28","count":0}, ...]
#   { "days": [{"date":"...", "count":N}, ...] }       # extra fields OK
#
# Dates must be YYYY-MM-DD in the user's tz (default America/Los_Angeles).
# Missing days inside the heatmap window are zero-filled; dates outside
# are silently dropped.
#
# Example URLs:
#   X_DATA_URL=https://gist.githubusercontent.com/you/abc123/raw/days.json
#   X_DATA_URL=https://raw.githubusercontent.com/you/twitter-data/main/days.json
#   X_DATA_URL=https://my-scraper.fly.dev/days.json
X_DATA_URL=

# X_NITTER_HOST — self-hosted Nitter fallback. Use this only if you've
# done the docs/SELF_HOST_NITTER.md Fly.io walkthrough. Public Nitter
# instances (nitter.net etc) are tried as a last-resort fallback when
# this is unset, but they're almost always blocked from Vercel egress.
#
# Hostname only — no protocol, no trailing slash, no path. The dashboard
# will hit https://<host>/<handle>/rss.
#
# Example: X_NITTER_HOST=my-nitter.fly.dev
X_NITTER_HOST=

# --- Dashboard auth (Phase 3+) ------------------------------------------
NERV_PILOT_TOKEN=

# --- One-liner LLM (optional) -------------------------------------------
# If set, the dashboard's nudge line is generated by Claude Haiku.
# If unset, a deterministic rule-based pool is used (free, no API call).
# Get a key at https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=

# --- Misc ----------------------------------------------------------------
# IANA timezone used for day-bucketing & streak math.
NERV_TZ=America/Los_Angeles
