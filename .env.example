# --- GitHub --------------------------------------------------------------
# PAT from https://github.com/settings/tokens
# Scopes:  read:user   (required, lets private contribs show in your graph total)
#          repo        (optional, only if you want commit messages/refs later)
GITHUB_TOKEN=
GITHUB_LOGIN=anishthite

# --- Twitter / X ---------------------------------------------------------
# Your X handle (no leading @).
#
# At runtime the dashboard does NOT fetch from X. The tweet day-counts are
# read from a bundled JSON file at apps/web/src/data/x-days.json which is
# refreshed by a daily GitHub Action (.github/workflows/refresh-x-days.yml)
# that calls socialdata.tools and commits the new counts back to main.
#
# X_LOGIN is still used for panel-presence logic: if it's empty the X panel
# is hidden entirely. The Action also reads X_LOGIN (via the workflow env)
# to know whose tweets to fetch.
X_LOGIN=anishthite

# --- Dashboard auth (Phase 3+) ------------------------------------------
NERV_PILOT_TOKEN=

# --- One-liner LLM (optional) -------------------------------------------
# If set, the dashboard's nudge line is generated by Claude Haiku.
# If unset, a deterministic rule-based pool is used (free, no API call).
# Get a key at https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=

# --- Misc ----------------------------------------------------------------
# IANA timezone used for day-bucketing & streak math.
NERV_TZ=America/Los_Angeles

# --- GitHub Action secrets (NOT for .env.local) -------------------------
# These belong in GitHub → Settings → Secrets and variables → Actions.
# The runtime app never reads them; only the daily refresh workflow does.
#
# SOCIALDATA_API_KEY — Bearer token for https://api.socialdata.tools.
#   Used by scripts/refresh-x-days.ts (invoked by the daily Action) to
#   look up the user_id and paginate `from:<handle> since:<date>`.
#   Required for the workflow to succeed; not required for `pnpm dev`
#   or any user-facing render.
